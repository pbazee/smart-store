# ============================================================================
# SMARTEST STORE KE - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env.local and fill in your actual values
# For Vercel deployment, add these as Environment Variables in your project settings
# ============================================================================

# ============================================================================
# AUTHENTICATION & SESSION (REQUIRED)
# ============================================================================
# Generate a secure secret: openssl rand -base64 32
AUTH_SESSION_SECRET=replace-with-a-long-random-string-use-openssl

# ============================================================================
# DATABASE (REQUIRED) - Supabase PostgreSQL
# ============================================================================
# DATABASE_URL: Use the POOLED connection string from Supabase (port 6543)
# Get this from: Supabase Dashboard → Connection Pooler → PostgreSQL → URI
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL="postgresql://postgres:yourpassword@db.yourproject.supabase.co:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=10&connect_timeout=30&pool_timeout=60"

# DIRECT_URL: Use the DIRECT connection string from Supabase (port 5432)
# Get this from: Supabase Dashboard → Connection String → PostgreSQL → Direct
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DIRECT_URL="postgresql://postgres:yourpassword@db.yourproject.supabase.co:5432/postgres?sslmode=require&connection_limit=10&pool_timeout=60"

# ============================================================================
# SUPABASE API (REQUIRED)
# ============================================================================
# NEXT_PUBLIC_SUPABASE_URL: Your Supabase project URL
# Get this from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://yourproject.supabase.co

# NEXT_PUBLIC_SUPABASE_ANON_KEY: Public anon key for client-side auth
# Get this from: Supabase Dashboard → Settings → API → Anon Key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# SUPABASE_SERVICE_ROLE_KEY: Secret key for server-side admin operations
# Get this from: Supabase Dashboard → Settings → API → Service Role Secret
# ⚠️ KEEP THIS SECRET - Never commit or expose in frontend code
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ============================================================================
# SUPABASE STORAGE BUCKETS (OPTIONAL - used for image uploads)
# ============================================================================
SUPABASE_HOMEPAGE_CATEGORY_BUCKET=homepage-categories
SUPABASE_HERO_SLIDE_BUCKET=hero-slides
SUPABASE_BLOG_IMAGE_BUCKET=blog-images
SUPABASE_POPUP_IMAGE_BUCKET=popup-images

# ============================================================================
# CLERK AUTHENTICATION (CURRENTLY UNUSED - OPTIONAL)
# ============================================================================
# Note: Currently using custom email/password auth. Clerk keys are for future use.
# If you want to add Clerk OAuth (Google, Email, etc.), uncomment and fill these:
#
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_publishable_key
# CLERK_SECRET_KEY=sk_live_your_clerk_secret_key

# ============================================================================
# PAYSTACK PAYMENT PROCESSING (REQUIRED for payments)
# ============================================================================
# Get these from: Paystack Dashboard → Settings → API Keys and Webhooks
# LIVE KEYS: Use pk_live_* and sk_live_* for production
# TEST KEYS: Use pk_test_* and sk_test_* for testing

NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key

# ============================================================================
# EMAIL SERVICE - RESEND (OPTIONAL - used for transactional emails)
# ============================================================================
# Get this from: https://resend.com → API Keys
RESEND_API_KEY=re_your_resend_api_key

# Optional: Custom "From" email address (defaults to onboarding@resend.dev)
# RESEND_FROM_EMAIL="Smartest Store KE <noreply@smartest-store-ke.com>"

# ============================================================================
# DATA MODE (Development use only)
# ============================================================================
# Set to true to use mock/demo data instead of database
# Should ALWAYS be false in production
USE_MOCK_DATA=false

# ============================================================================
# VERCEL DEPLOYMENT
# ============================================================================
# DO NOT SET THESE IN .env.local - They are auto-configured by Vercel
# But here's what Vercel sets:
#
# - NODE_ENV=production (automatically set)
# - CI=true (automatically set)
# - VERCEL=1 (automatically set)
# - VERCEL_ENV=production (for production deployments)

